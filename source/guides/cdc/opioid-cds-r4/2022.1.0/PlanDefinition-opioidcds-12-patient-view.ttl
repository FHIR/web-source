  fhir:version [ fhir:v "2022.1.0"] ; # 
  fhir:name [ fhir:v "PlanDefinition_Recommendation_12_Patient_View"] ; # 
  fhir:title [ fhir:v "Recommendation #12 - Evidence-based Treatment for Patients with Opioid Use Disorder (patient-view)"] ; # 
  fhir:type [
     fhir:coding ( [
       fhir:system [
         fhir:v "http://terminology.hl7.org/CodeSystem/plan-definition-type"^^xsd:anyURI ;
         fhir:l <http://terminology.hl7.org/CodeSystem/plan-definition-type>
