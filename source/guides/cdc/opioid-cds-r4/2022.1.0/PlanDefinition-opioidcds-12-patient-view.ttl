         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "// Recommendation 12\ndefine \"Evidence Based Treatment Criteria For Opioid Use Disorder\":\n  true"
       ]
     ] [
       fhir:url [
         fhir:v "displaySequence"^^xsd:anyURI ;
         fhir:l fhir:displaySequence
       ] ;
