     fhir:title [ fhir:v "When Initiating Opioid Therapy, Utilize Immediate Release Opioids" ] ;
     fhir:description [ fhir:v "Recommend prescribing immediate release opioids instead of extended-release or long-acting opioids\r\n\r\n[For guidance regarding prescribing extended release/ long-acting opioids, see Recommendation 3 of the 2022 CDC Clinical Practice Guideline](https://www.cdc.gov/mmwr/volumes/71/rr/rr7103a1.htm#Recommendation3)." ] ;
