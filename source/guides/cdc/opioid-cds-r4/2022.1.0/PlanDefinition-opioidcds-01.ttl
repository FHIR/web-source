       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "define \"Exclusion Criteria\":\n  false"
