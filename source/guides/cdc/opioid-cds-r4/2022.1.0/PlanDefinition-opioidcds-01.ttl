     ] )
  ] ) ; # 
  fhir:description [ fhir:v "Nonopioid therapies are at least as effective as opioids for many common types of acute pain. Clinicians should maximize use of nonpharmacologic and nonopioid pharmacologic therapies as appropriate for the specific condition and patient and only consider opioid therapy for acute pain if benefits are anticipated to outweigh risks to the patient. Before prescribing opioid therapy for acute pain, clinicians should discuss with patients the realistic benefits and known risks of opioid therapy."] ; # 
  fhir:useContext ( [
     fhir:code [
       fhir:system [
         fhir:v "http://terminology.hl7.org/CodeSystem/usage-context-type"^^xsd:anyURI ;
         fhir:l <http://terminology.hl7.org/CodeSystem/usage-context-type>
       ] ;
       fhir:code [ fhir:v "focus" ] ;
       fhir:display [ fhir:v "Clinical Focus" ]
     ] ;
