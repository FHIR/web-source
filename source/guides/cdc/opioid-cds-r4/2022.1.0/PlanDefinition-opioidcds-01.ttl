  fhir:version [ fhir:v "2022.1.0"] ; # 
  fhir:name [ fhir:v "PlanDefinition_Recommendation_01_Order_Sign"] ; # 
  fhir:title [ fhir:v "Recommendation #1 - Nonpharmacologic and Nonopioid Pharmacologic Therapy Consideration"] ; # 
  fhir:type [
     fhir:coding ( [
