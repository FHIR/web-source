       ]
     ] ) ;
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
     ]
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "libraryName"^^xsd:anyURI ;
         fhir:l fhir:libraryName
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "OpioidCDSRoutines"
       ]
     ] [
       fhir:url [
         fhir:v "name"^^xsd:anyURI ;
         fhir:l fhir:name
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "Is Active Cancer Treatment?"
       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "define \"Is Active Cancer Treatment?\":\n  if (Config.\"Active Cancer Treatment Encounters Condition Is Enabled\") \n    then \"Has Two or More Encounters with Cancer Diagnosis During Encounter Period\"\n      or \"Has Active Cancer Diagnosis on Problem List\"\n  else false"
       ]
     ] [
       fhir:url [
         fhir:v "displaySequence"^^xsd:anyURI ;
         fhir:l fhir:displaySequence
       ] ;
       fhir:value [
         a fhir:Integer ;
         fhir:v 17
       ]
     ] ) ;
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
     ]
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "libraryName"^^xsd:anyURI ;
         fhir:l fhir:libraryName
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "OpioidCDSCommonConfig"
       ]
     ] [
       fhir:url [
         fhir:v "name"^^xsd:anyURI ;
         fhir:l fhir:name
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "End-Stage Disease Criteria Enabled"
       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "// CDC 2022 General Inclusion Criteria\ndefine \"End-Stage Disease Criteria Enabled\":\n  true"
       ]
     ] [
       fhir:url [
         fhir:v "displaySequence"^^xsd:anyURI ;
         fhir:l fhir:displaySequence
       ] ;
       fhir:value [
         a fhir:Integer ;
         fhir:v 18
       ]
     ] ) ;
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
     ]
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "libraryName"^^xsd:anyURI ;
         fhir:l fhir:libraryName
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "OpioidCDSRoutines"
       ]
     ] [
       fhir:url [
         fhir:v "name"^^xsd:anyURI ;
         fhir:l fhir:name
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "Conditions Likely Terminal for Opioid Prescribing"
       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "define \"Conditions Likely Terminal for Opioid Prescribing\":\n  if (Config.\"End-Stage Disease Criteria Enabled\") then\n    exists (\n      Common.\"US Core-Categorized Conditions\" EOLC\n        where EOLC.code in Common.\"Conditions likely terminal for opioid prescribing\"\n          // and EOLC.clinicalStatus in Common.\"Active Condition\"\n    )\n  else false"
       ]
     ] [
       fhir:url [
         fhir:v "displaySequence"^^xsd:anyURI ;
         fhir:l fhir:displaySequence
       ] ;
       fhir:value [
         a fhir:Integer ;
         fhir:v 19
       ]
     ] ) ;
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
     ]
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "libraryName"^^xsd:anyURI ;
         fhir:l fhir:libraryName
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "OpioidCDSRoutines"
       ]
     ] [
       fhir:url [
         fhir:v "name"^^xsd:anyURI ;
         fhir:l fhir:name
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "CDC 2022 Guideline General Inclusion Criteria"
       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "define \"CDC 2022 Guideline General Inclusion Criteria\":\n  not \"Patient Age Less Than 18\"\n    and not \"Condition Positive for Sickle Cell\"\n    and not \"Is Active Cancer Treatment?\"\n    and not \"Conditions Likely Terminal for Opioid Prescribing\""
       ]
     ] [
       fhir:url [
         fhir:v "displaySequence"^^xsd:anyURI ;
         fhir:l fhir:displaySequence
       ] ;
       fhir:value [
         a fhir:Integer ;
         fhir:v 20
       ]
     ] ) ;
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
     ]
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "libraryName"^^xsd:anyURI ;
         fhir:l fhir:libraryName
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "OpioidCDSCommonConfig"
       ]
     ] [
       fhir:url [
         fhir:v "name"^^xsd:anyURI ;
         fhir:l fhir:name
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "Opioid Naive Prescription Condition Is Enabled"
       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "// Opioid Naive\ndefine \"Opioid Naive Prescription Condition Is Enabled\":\n  true"
