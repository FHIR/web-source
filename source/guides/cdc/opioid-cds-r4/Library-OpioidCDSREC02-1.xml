                  </a:s>
                  <a:s>></a:s>
               </a:s>
            </a:s>
         </annotation>
         <parameterTypeSpecifier localId="217" locator="50:32-50:54" xsi:type="ListTypeSpecifier">
            <elementType localId="218" locator="50:37-50:53" name="fhir:MedicationRequest" xsi:type="NamedTypeSpecifier"/>
