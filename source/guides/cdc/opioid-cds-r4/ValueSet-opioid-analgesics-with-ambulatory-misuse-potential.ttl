       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://www.securityrisksolutions.com" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "All opioid clinical drugs except cough medications, antispasmodics, or those restricted to surgical use only as identified by those using an injectable form."] ; # 
