       fhir:reference [
         fhir:l <http://fhir.org/guides/cdc/opioid-cds/StructureDefinition/cdc-valueset-dataelement-scope> ;
         fhir:reference [ fhir:v "StructureDefinition/cdc-valueset-dataelement-scope" ]
       ] ;
