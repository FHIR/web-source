        <tr>
          <td colspan="2">
            <table>
              <tr><th><a id="cql-content"><b>Content: </b></a> text/cql</th></tr>
              <tr><td><pre style="max-width: 1084px;"><code class="language-cql">library HelloWorldPatientView version '1.0.0'

using FHIR version '4.0.1'

include FHIRHelpers version '4.0.1'

context Patient

define &quot;Info&quot;:
  'info'

define &quot;Warning&quot;:
  'warning'

define &quot;Critical&quot;:
  'critical'

define &quot;Main Action Condition Expression Is True&quot;:
  true

define &quot;Get Title&quot;:
  'Hello World!'

define &quot;Get Description&quot;:
  'The CDS Service is alive and communicating successfully!'

define &quot;Get Indicator&quot;:
  'info'
</code></pre></td></tr>
            </table>
          </td>
        </tr>
        
        
        
        
        
