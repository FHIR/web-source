  <extension url="http://fhir.org/guides/cdc/opioid-cds/StructureDefinition/cdc-valueset-clinical-focus">
    <valueString value="All opioid clinical drugs except cough medications, antispasmodics, or those restricted to surgical use only."/>
  </extension>
  <extension url="http://fhir.org/guides/cdc/opioid-cds/StructureDefinition/cdc-valueset-dataelement-scope">
    <valueString value="Medication"/>
  </extension>
  <extension url="http://fhir.org/guides/cdc/opioid-cds/StructureDefinition/cdc-valueset-inclusion-criteria">
    <valueString value="All opioid-class medications"/>
  </extension>
  <extension url="http://fhir.org/guides/cdc/opioid-cds/StructureDefinition/cdc-valueset-exclusion-criteria">
    <valueString value="All medications including ingredients intended to treat cough or act as an antispasmodic. All injectable forms."/>
  </extension>
