    },
    {
      "url" : "statement",
      "valueString" : "define function GetExpectedColumn(Content String):\n  '<td class=\\\"details-table-cell\\\">' & Content & '<\\/td>'"
    },
    {
      "url" : "displaySequence",
      "valueInteger" : 133
    }],
    "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
  },
  {
