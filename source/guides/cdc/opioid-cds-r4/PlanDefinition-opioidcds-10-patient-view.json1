      "valueString" : "// Functions\n\ndefine function GetUnexpectedColumn(Result String, Superscript String):\n  '<td class=\\\"details-table-cell-unexpected\\\">' & Result & '<sup>' & Superscript & '<\\/sup><\\/td>'"
    },
    {
