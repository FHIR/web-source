      "valueString" : "Rx Lookback Period"
    },
    {
      "url" : "statement",
      "valueString" : "define \"Rx Lookback Period\":\n  Interval[Today() - 12 months - 31 days, Today()]"
    },
    {
      "url" : "displaySequence",
      "valueInteger" : 39
    }],
