    {
      "url" : "statement",
      "valueString" : "define function GetFooterColumn(colspan Integer, message String):\n  '<td class=\\\"details-table-cell\\\"' & ' colspan=' & ToString(colspan) & '>' & message & '<\\/td>'"
    },
