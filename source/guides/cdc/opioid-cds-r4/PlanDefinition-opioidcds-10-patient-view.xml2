                            <pre style="max-width: 990px;"><code class="language-cql">define function CreateDetailWithoutPossibleUnexpectedNegative(TheSubstance String, ThePosLabs List&lt;Observation&gt;, TheNegLabs List&lt;Observation&gt;):
