       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "define \"Patient Age Less Than 18\":\n  if (Config.\"Age Less than 18 Years Is Enabled\") then\n    AgeInYearsAt(Today()) < 18\n  else false"
       ]
     ] [
       fhir:url [
         fhir:v "displaySequence"^^xsd:anyURI ;
         fhir:l fhir:displaySequence
       ] ;
