       fhir:value [
         a fhir:String ;
         fhir:v "Is Benzodiazepine or CNS Depressant?"
       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "define function \"Is Benzodiazepine or CNS Depressant?\"(value List<MedicationRequest>):\n  (\"Get MedicationRequest Medication as Code\"(value)) Rx\n    where Rx.medication in \"Benzodiazepine medications\"\n      or Rx.medication in \"CNS Depressant Medications\"\n      and Rx.category in \"Community\""
       ]
