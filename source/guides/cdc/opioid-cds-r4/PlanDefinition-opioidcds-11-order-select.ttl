       ] ;
       fhir:value [
         a fhir:CodeableConcept ;
         fhir:coding ( [
           fhir:system [
             fhir:v "http://terminology.hl7.org/CodeSystem/evidence-quality"^^xsd:anyURI ;
             fhir:l <http://terminology.hl7.org/CodeSystem/evidence-quality>
           ] ;
           fhir:code [ fhir:v "low" ] ;
