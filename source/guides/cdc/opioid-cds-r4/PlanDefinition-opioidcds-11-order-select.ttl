         a fhir:String ;
         fhir:v "OpioidCDSREC11OrderSelect"
       ]
     ] [
       fhir:url [
         fhir:v "name"^^xsd:anyURI ;
         fhir:l fhir:name
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "Exclusion Criteria"
       ]
     ] [
       fhir:url [
         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "define \"Exclusion Criteria\":\n  Common.\"End of Life Assessment\""
       ]
     ] [
       fhir:url [
         fhir:v "displaySequence"^^xsd:anyURI ;
         fhir:l fhir:displaySequence
       ] ;
       fhir:value [
         a fhir:Integer ;
         fhir:v 32
       ]
     ] ) ;
     fhir:url [
