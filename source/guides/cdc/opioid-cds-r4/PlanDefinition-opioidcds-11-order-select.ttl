         fhir:v "statement"^^xsd:anyURI ;
         fhir:l fhir:statement
       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "define function ToString(value string): value.value"
       ]
     ] [
       fhir:url [
         fhir:v "displaySequence"^^xsd:anyURI ;
         fhir:l fhir:displaySequence
       ] ;
       fhir:value [
         a fhir:Integer ;
         fhir:v 36
       ]
