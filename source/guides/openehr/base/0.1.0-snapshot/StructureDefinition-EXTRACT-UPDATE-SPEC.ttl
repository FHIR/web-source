         fhir:max [ fhir:v "1" ]
       ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "boolean"^^xsd:anyURI ;
           fhir:l fhir:boolean
         ]
       ] ) ;
       fhir:isModifier [ fhir:v false ]
     ] [
       fhir:id [ fhir:v "EXTRACT_UPDATE_SPEC.repeat-period" ] ;
       fhir:path [ fhir:v "EXTRACT_UPDATE_SPEC.repeat_period" ] ;
       fhir:short [ fhir:v "Period for resending update Extracts in response to original Request." ] ;
       fhir:definition [ fhir:v "Period for resending update Extracts in response to original Request." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:base [
         fhir:path [ fhir:v "EXTRACT_UPDATE_SPEC.repeat_period" ] ;
         fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
         fhir:max [ fhir:v "1" ]
       ] ;
       fhir:type ( [
         fhir:code [
