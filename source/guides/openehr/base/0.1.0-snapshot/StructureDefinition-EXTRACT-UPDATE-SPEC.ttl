       ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "0.1.0-snapshot"
       ]
     ] ) ;
     fhir:element ( [
       fhir:id [ fhir:v "EXTRACT_UPDATE_SPEC" ] ;
       fhir:path [ fhir:v "EXTRACT_UPDATE_SPEC" ] ;
       fhir:short [ fhir:v "Specification of the how the request should be processed by server." ] ;
       fhir:definition [ fhir:v "Specification of the how the request should be processed by server. The request can be persisted in the server, meaning that a) it can be re-activated by the requesting system simply by indicating Request id, and b) that a changes-only pattern of Extract updates can be set up. To achieve this, the server has to remember what was sent in the previous response.\n\nThe update mode may be event-driven and periodic update or a mixture of both. The candidate items to be sent each time are the result of re-evaluating the content and versioning parts of the specification; what is actually sent is determined by the `_send_changes_only_` flag." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
       fhir:base [
         fhir:path [ fhir:v "Base" ] ;
         fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
         fhir:max [ fhir:v "*" ]
       ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "Overall_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Overall validity must be present" ] ;
         fhir:expression [ fhir:v "repeat_period.exists() or trigger_events.exists()" ]
       ] [
         fhir:key [ fhir:v "Trigger_events_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Trigger events validity must be present" ] ;
         fhir:expression [ fhir:v "trigger_events.exists() implies trigger_events.empty().not()" ]
       ] [
         fhir:key [ fhir:v "Send_changes_only_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Send changes only validity must satisfy conditional constraints" ] ;
         fhir:expression [ fhir:v "null # TODO: manual translation needed" ]
       ] ) ;
       fhir:isModifier [ fhir:v false ] ;
       fhir:mapping ( [
         fhir:identity [ fhir:v "rim" ] ;
         fhir:map [ fhir:v "n/a" ]
       ] )
     ] [
       fhir:id [ fhir:v "EXTRACT_UPDATE_SPEC.persist-in-server" ] ;
       fhir:path [ fhir:v "EXTRACT_UPDATE_SPEC.persist_in_server" ] ;
       fhir:short [ fhir:v "If True, this Request is persisted in the server until further notice." ] ;
       fhir:definition [ fhir:v "If True, this Request is persisted in the server until further notice." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:base [
         fhir:path [ fhir:v "EXTRACT_UPDATE_SPEC.persist_in_server" ] ;
