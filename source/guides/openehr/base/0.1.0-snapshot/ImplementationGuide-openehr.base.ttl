         fhir:l <http://openehr.org/fhir/StructureDefinition/PARTY-IDENTITY> ;
         fhir:reference [ fhir:v "StructureDefinition/PARTY-IDENTITY" ]
       ] ;
       fhir:name [ fhir:v "PARTY_IDENTITY" ] ;
       fhir:description [ fhir:v "An identity  owned  by a Party, such as a person name or company name, and which is used by the Party to identify itself. Actual structure is archetyped." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
