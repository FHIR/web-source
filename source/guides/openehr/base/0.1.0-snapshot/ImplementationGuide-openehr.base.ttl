       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/FOLDER> ;
         fhir:reference [ fhir:v "StructureDefinition/FOLDER" ]
       ] ;
       fhir:name [ fhir:v "FOLDER" ] ;
       fhir:description [ fhir:v "The concept of a named folder.\n\nNOTE: It is strongly recommended that the inherited attribute `_uid_` be populated in _top-level_ (i.e. tree-root) `FOLDER` objects, using the UID copied from the `_object_id()_` of the `_uid_` field of the enclosing `VERSION` object. +\nFor example, the `ORIGINAL_VERSION.uid` `87284370-2D4B-4e3d-A3F3-F303D2F4F34B::uk.nhs.ehr1::2`  would be copied to the `_uid_` field of the top `FOLDER` object." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/GENERIC-CONTENT-ITEM> ;
         fhir:reference [ fhir:v "StructureDefinition/GENERIC-CONTENT-ITEM" ]
       ] ;
       fhir:name [ fhir:v "GENERIC_CONTENT_ITEM" ] ;
       fhir:description [ fhir:v "Single item in generic extract, designed for 13606 and CDA data." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
