         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/INTERVAL-EVENT> ;
         fhir:reference [ fhir:v "StructureDefinition/INTERVAL-EVENT" ]
       ] ;
       fhir:name [ fhir:v "INTERVAL_EVENT" ] ;
       fhir:description [ fhir:v "Defines a single interval event in a series." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/ISM-TRANSITION> ;
         fhir:reference [ fhir:v "StructureDefinition/ISM-TRANSITION" ]
       ] ;
       fhir:name [ fhir:v "ISM_TRANSITION" ] ;
       fhir:description [ fhir:v "Model of a transition in the Instruction State Machine, caused by a careflow step. The attributes document the careflow step as well as the ISM transition." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/ITEM-LIST> ;
         fhir:reference [ fhir:v "StructureDefinition/ITEM-LIST" ]
       ] ;
       fhir:name [ fhir:v "ITEM_LIST" ] ;
       fhir:description [ fhir:v "Logical list data structure, where each item has a value and can be referred to by a name and a positional index in the list. The list may be empty. \n\n`ITEM_LIST` is used to represent any data which is logically a list of values, such as blood pressure, most protocols, many blood tests etc. \n\nNot to be used for time-based lists, which should be represented with the proper temporal class, i.e. `HISTORY`." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/ITEM-SINGLE> ;
         fhir:reference [ fhir:v "StructureDefinition/ITEM-SINGLE" ]
       ] ;
       fhir:name [ fhir:v "ITEM_SINGLE" ] ;
       fhir:description [ fhir:v "Logical single value data structure. Used to represent any data which is logically a single value, such as a person's height or weight." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical:abstract"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/ITEM-STRUCTURE> ;
         fhir:reference [ fhir:v "StructureDefinition/ITEM-STRUCTURE" ]
       ] ;
       fhir:name [ fhir:v "ITEM_STRUCTURE" ] ;
       fhir:description [ fhir:v "Abstract parent class of all spatial data types." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/ITEM-TABLE> ;
         fhir:reference [ fhir:v "StructureDefinition/ITEM-TABLE" ]
       ] ;
       fhir:name [ fhir:v "ITEM_TABLE" ] ;
       fhir:description [ fhir:v "Logical relational database style table data structure, in which columns are named and ordered with respect to each other. Implemented using Cluster-per-row encoding. Each row Cluster must have an identical number of Elements, each of which in turn must have identical names and value types in the corresponding positions in each row. \n\nSome columns may be designated  key' columns, containing key data for each row, in the manner of relational tables. This allows row-naming, where each row represents a body site, a blood antigen etc. All values in a column have the same data type. \n\nUsed for representing any data which is logically a table of values, such as blood pressure, most protocols, many blood tests etc. \n\nMisuse: Not to be used for time-based data, which should be represented with the temporal class `HISTORY`. The table may be empty." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/ITEM-TAG> ;
         fhir:reference [ fhir:v "StructureDefinition/ITEM-TAG" ]
       ] ;
       fhir:name [ fhir:v "ITEM_TAG" ] ;
       fhir:description [ fhir:v "A tag with optional value that is associated with a target information entity identified by a UID." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/ITEM-TREE> ;
         fhir:reference [ fhir:v "StructureDefinition/ITEM-TREE" ]
       ] ;
       fhir:name [ fhir:v "ITEM_TREE" ] ;
       fhir:description [ fhir:v "Logical tree data structure. The tree may be empty. Used for representing data which are logically a tree such as audiology results, microbiology results, biochemistry results." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical:abstract"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/ITEM> ;
         fhir:reference [ fhir:v "StructureDefinition/ITEM" ]
       ] ;
       fhir:name [ fhir:v "ITEM" ] ;
       fhir:description [ fhir:v "The abstract parent of `CLUSTER` and `ELEMENT` representation classes." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/LINK> ;
         fhir:reference [ fhir:v "StructureDefinition/LINK" ]
       ] ;
       fhir:name [ fhir:v "LINK" ] ;
       fhir:description [ fhir:v "The `LINK` type defines a logical relationship between two items, such as two `ENTRYs` or an `ENTRY` and a `COMPOSITION`. Links can be used across compositions, and across EHRs. Links can potentially be used between interior (i.e. non archetype root) nodes, although this probably should be prevented in archetypes. Multiple `LINKs` can be attached to the root object of any archetyped structure to give the effect of a 1->N link.\n\n1:1 and 1:N relationships between archetyped content elements (e.g. `ENTRYs`) can be expressed by using one, or more than one, respectively, `LINKs`. Chains of links can be used to see  problem threads  or other logical groupings of items. \n\nLinks should be between archetyped structures only, i.e. between objects representing complete domain concepts because relationships between sub-elements of whole concepts are not necessarily meaningful, and may be downright confusing. Sensible links only exist between whole `ENTRYs`, `SECTIONs`, `COMPOSITIONs` and so on." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/LOCATABLE-REF> ;
         fhir:reference [ fhir:v "StructureDefinition/LOCATABLE-REF" ]
       ] ;
       fhir:name [ fhir:v "LOCATABLE_REF" ] ;
       fhir:description [ fhir:v "Reference to a LOCATABLE instance inside the top-level content structure inside a VERSION<T> identified by the id attribute. The path attribute is applied to the object that VERSION.data points to" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical:abstract"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/LOCATABLE> ;
         fhir:reference [ fhir:v "StructureDefinition/LOCATABLE" ]
       ] ;
       fhir:name [ fhir:v "LOCATABLE" ] ;
       fhir:description [ fhir:v "Root class of all information model classes that can be archetyped. Most classes in the openEHR reference model inherit from the `LOCATABLE` class, which defines the idea of  locatability in an archetyped structure. `LOCATABLE` defines a runtime name and an `_archetype_node_id_`." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/MEASUREMENT-SERVICE> ;
         fhir:reference [ fhir:v "StructureDefinition/MEASUREMENT-SERVICE" ]
       ] ;
       fhir:name [ fhir:v "MEASUREMENT_SERVICE" ] ;
       fhir:description [ fhir:v "Defines an object providing proxy access to a measurement information service." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical:abstract"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/MESSAGE-CONTENT> ;
         fhir:reference [ fhir:v "StructureDefinition/MESSAGE-CONTENT" ]
       ] ;
       fhir:name [ fhir:v "MESSAGE_CONTENT" ] ;
       fhir:description [ fhir:v "Abstract parent of message payload types." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/MESSAGE> ;
         fhir:reference [ fhir:v "StructureDefinition/MESSAGE" ]
       ] ;
       fhir:name [ fhir:v "MESSAGE" ] ;
       fhir:description [ fhir:v "A “message” is an authored, possibly signed, piece of content intended for one or more recipients. Since the recipient may or may not be known directly, recipients are specified in the `ADDRESSED_MESSAGE` class." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
