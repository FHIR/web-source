       ] ;
       fhir:name [ fhir:v "REVISION_HISTORY" ] ;
       fhir:description [ fhir:v "Purpose Defines the notion of a revision history of audit items, each associated with the version for which that audit was committed. The list is in most-recent-first order." ]
     ] [
