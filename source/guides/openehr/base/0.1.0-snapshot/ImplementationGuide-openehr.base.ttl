       ] ;
       fhir:name [ fhir:v "REVISION_HISTORY_ITEM" ] ;
       fhir:description [ fhir:v "An entry in a revision history, corresponding to a version from a versioned container. Consists of `AUDIT_DETAILS` instances with revision identifier of the revision to which the `AUDIT_DETAILS` instance belongs." ]
