         fhir:reference [ fhir:v "StructureDefinition/PERSON" ]
       ] ;
       fhir:name [ fhir:v "PERSON" ] ;
       fhir:description [ fhir:v "Generic description of persons. Provides a dedicated type to which Person archetypes can be targeted." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
