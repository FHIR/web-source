         fhir:l <http://openehr.org/fhir/StructureDefinition/PARTY-RELATIONSHIP> ;
         fhir:reference [ fhir:v "StructureDefinition/PARTY-RELATIONSHIP" ]
       ] ;
       fhir:name [ fhir:v "PARTY_RELATIONSHIP" ] ;
       fhir:description [ fhir:v "Generic description of a relationship between parties." ]
     ] [
