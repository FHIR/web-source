       ] ;
       fhir:name [ fhir:v "PARTY_SELF" ] ;
       fhir:description [ fhir:v "Party proxy representing the subject of the record. Used to indicate that the party is the owner of the record. May or may not have `_external_ref_` set." ]
     ] [
