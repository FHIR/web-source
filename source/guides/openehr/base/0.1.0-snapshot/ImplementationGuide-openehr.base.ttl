         fhir:reference [ fhir:v "StructureDefinition/REFERENCE-RANGE" ]
       ] ;
       fhir:name [ fhir:v "REFERENCE_RANGE" ] ;
       fhir:description [ fhir:v "Defines a named range to be associated with any `DV_ORDERED` datum. Each such range is particular to the patient and context, e.g. sex, age, and any other factor which affects ranges. May be used to represent normal, therapeutic, dangerous, critical etc ranges." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
