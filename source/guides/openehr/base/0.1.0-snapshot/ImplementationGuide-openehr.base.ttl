         fhir:reference [ fhir:v "StructureDefinition/RESOURCE-DESCRIPTION-ITEM" ]
       ] ;
       fhir:name [ fhir:v "RESOURCE_DESCRIPTION_ITEM" ] ;
       fhir:description [ fhir:v "Language-specific detail of resource description. When a resource is translated for use in another language environment, each `RESOURCE_DESCRIPTION_ITEM` needs to be copied and translated into the new language." ]
     ] [
