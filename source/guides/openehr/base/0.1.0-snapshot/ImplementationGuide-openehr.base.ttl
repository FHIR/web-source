         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/INSTRUCTION> ;
         fhir:reference [ fhir:v "StructureDefinition/INSTRUCTION" ]
       ] ;
       fhir:name [ fhir:v "INSTRUCTION" ] ;
       fhir:description [ fhir:v "Used to specify actions in the future. Enables simple and complex specifications to be expressed, including in a fully-computable workflow form. Used for any actionable statement such as medication and therapeutic orders, monitoring, recall and review. Enough details must be provided for the specification to be directly executed by an actor, either human or machine. \n\nNot to be used for plan items which are only specified in general terms." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
