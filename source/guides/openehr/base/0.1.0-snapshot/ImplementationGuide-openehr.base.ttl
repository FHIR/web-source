         fhir:reference [ fhir:v "StructureDefinition/PARTY-PROXY" ]
       ] ;
       fhir:name [ fhir:v "PARTY_PROXY" ] ;
       fhir:description [ fhir:v "Abstract concept of a proxy description of a party, including an optional link to data for this party in a demographic or other identity management system. Sub- typed into `PARTY_IDENTIFIED` and `PARTY_SELF`." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
