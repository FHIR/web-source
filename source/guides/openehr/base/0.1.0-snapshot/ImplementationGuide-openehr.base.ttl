         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/HISTORY> ;
         fhir:reference [ fhir:v "StructureDefinition/HISTORY" ]
       ] ;
       fhir:name [ fhir:v "HISTORY" ] ;
       fhir:description [ fhir:v "Root object of a linear history, i.e. time series structure. This is a generic class whose type parameter must be a descendant of `ITEM_STRUCTURE`, ensuring that each Event in the `_events_` of a given instance is of the same structural type, i.e. `ITEM_TREE`, `ITEM_LIST` etc.\n\nFor a periodic series of events, period will be set, and the time of each Event in the History must correspond; i.e. the `EVENT._offset_` must be a multiple of period for each Event. Missing events in a period History are however allowed." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/IMPORTED-VERSION> ;
         fhir:reference [ fhir:v "StructureDefinition/IMPORTED-VERSION" ]
       ] ;
       fhir:name [ fhir:v "IMPORTED_VERSION" ] ;
       fhir:description [ fhir:v "Versions whose content is an `ORIGINAL_VERSION` copied from another location; this class inherits `_commit_audit_` and `_contribution_` from `VERSION<T>`, providing imported versions with their own audit trail and Contribution, distinct from those of the imported `ORIGINAL_VERSION`." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/INSTRUCTION-DETAILS> ;
         fhir:reference [ fhir:v "StructureDefinition/INSTRUCTION-DETAILS" ]
       ] ;
       fhir:name [ fhir:v "INSTRUCTION_DETAILS" ] ;
       fhir:description [ fhir:v "Used to record details of the Instruction causing an Action." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
