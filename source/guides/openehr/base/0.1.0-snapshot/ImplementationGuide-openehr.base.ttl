           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/GROUP> ;
         fhir:reference [ fhir:v "StructureDefinition/GROUP" ]
       ] ;
       fhir:name [ fhir:v "GROUP" ] ;
       fhir:description [ fhir:v "A group is a real world group of parties which is created by another party, usually an organisation, for some specific purpose. A typical clinical example is that of the specialist care team, e.g.  cardiology team . The members of the group usually work together." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://openehr.org/fhir/StructureDefinition/HIER-OBJECT-ID> ;
         fhir:reference [ fhir:v "StructureDefinition/HIER-OBJECT-ID" ]
       ] ;
       fhir:name [ fhir:v "HIER_OBJECT_ID" ] ;
       fhir:description [ fhir:v "Concrete type corresponding to hierarchical identifiers of the form defined by UID_BASED_ID." ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
