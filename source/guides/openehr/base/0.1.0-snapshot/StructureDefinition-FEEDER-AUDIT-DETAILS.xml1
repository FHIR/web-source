      <valueString value="0.1.0-snapshot"/>
    </extension>
    <element id="FEEDER_AUDIT_DETAILS">
      <path value="FEEDER_AUDIT_DETAILS"/>
      <short value="Audit details for any system in a feeder system chain."/>
      <definition value="Audit details for any system in a feeder system chain. Audit details here means the general notion of who/where/when the information item to which the audit is attached was created. None of the attributes is defined as mandatory, however, in different scenarios, various combinations of attributes will usually be mandatory. This can be controlled by specifying feeder audit details in legacy archetypes. "/>
      <min value="0"/>
      <max value="*"/>
      <base>
        <path value="Base"/>
        <min value="0"/>
        <max value="*"/>
      </base>
      <constraint>
        <key value="System_id_valid"/>
        <severity value="error"/>
        <human value="System id valid must not be empty"/>
        <expression value="system_id.empty().not()"/>
      </constraint>
      <isModifier value="false"/>
      <mapping>
        <identity value="rim"/>
        <map value="n/a"/>
      </mapping>
    </element>
    <element id="FEEDER_AUDIT_DETAILS.system-id">
      <path value="FEEDER_AUDIT_DETAILS.system_id"/>
      <short value="Identifier of the system which handled the information item."/>
      <definition value="Identifier of the system which handled the information item. This is the IT system owned by the organisation legally responsible for handling the data, and at which the data were previously created or passed by an earlier system."/>
      <min value="1"/>
      <max value="1"/>
      <base>
        <path value="FEEDER_AUDIT_DETAILS.system_id"/>
        <min value="1"/>
        <max value="1"/>
      </base>
      <type>
        <code value="string"/>
      </type>
      <isModifier value="false"/>
    </element>
    <element id="FEEDER_AUDIT_DETAILS.location">
      <path value="FEEDER_AUDIT_DETAILS.location"/>
      <short value="Identifier of the particular site/facility within an organisation which handled the item."/>
      <definition value="Identifier of the particular site/facility within an organisation which handled the item. For computability, this identifier needs to be e.g. a PKI identifier which can be included in the identifier list of the `PARTY_IDENTIFIED` object."/>
      <min value="0"/>
      <max value="1"/>
      <base>
        <path value="FEEDER_AUDIT_DETAILS.location"/>
        <min value="0"/>
        <max value="1"/>
      </base>
      <type>
        <code value="http://openehr.org/fhir/StructureDefinition/PARTY-IDENTIFIED"/>
      </type>
      <isModifier value="false"/>
    </element>
    <element id="FEEDER_AUDIT_DETAILS.subject">
      <path value="FEEDER_AUDIT_DETAILS.subject"/>
      <short value="Identifiers for subject of the received information item."/>
      <definition value="Identifiers for subject of the received information item."/>
      <min value="0"/>
      <max value="1"/>
      <base>
        <path value="FEEDER_AUDIT_DETAILS.subject"/>
        <min value="0"/>
        <max value="1"/>
      </base>
      <type>
        <code value="http://openehr.org/fhir/StructureDefinition/PARTY-PROXY"/>
      </type>
      <isModifier value="false"/>
    </element>
    <element id="FEEDER_AUDIT_DETAILS.provider">
      <path value="FEEDER_AUDIT_DETAILS.provider"/>
      <short value="Optional provider(s) who created, committed, forwarded or otherwise handled the item."/>
      <definition value="Optional provider(s) who created, committed, forwarded or otherwise handled the item."/>
      <min value="0"/>
