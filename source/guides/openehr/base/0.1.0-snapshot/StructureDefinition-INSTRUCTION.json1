    {
      "id" : "INSTRUCTION.archetype-details",
      "path" : "INSTRUCTION.archetype_details",
      "short" : "Details of archetyping used on this node.",
      "definition" : "Details of archetyping used on this node.",
      "min" : 0,
      "max" : "1",
      "base" : {
        "path" : "LOCATABLE.archetype_details",
        "min" : 0,
        "max" : "1"
