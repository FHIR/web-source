  <snapshot>
    <extension url="http://hl7.org/fhir/tools/StructureDefinition/snapshot-base-version">
      <valueString value="0.1.0-snapshot"/>
    </extension>
    <element id="RESOURCE_DESCRIPTION_ITEM">
      <path value="RESOURCE_DESCRIPTION_ITEM"/>
      <short value="Language-specific detail of resource description."/>
      <definition value="Language-specific detail of resource description. When a resource is translated for use in another language environment, each `RESOURCE_DESCRIPTION_ITEM` needs to be copied and translated into the new language."/>
      <min value="0"/>
      <max value="*"/>
      <base>
        <path value="Base"/>
        <min value="0"/>
        <max value="*"/>
      </base>
      <constraint>
        <key value="Purpose_valid"/>
        <severity value="error"/>
        <human value="Purpose valid must not be empty"/>
        <expression value="purpose.empty().not()"/>
      </constraint>
      <constraint>
        <key value="Use_valid"/>
        <severity value="error"/>
        <human value="Use valid must be present"/>
        <expression value="use.exists() implies use.empty().not()"/>
      </constraint>
      <constraint>
        <key value="misuse_valid"/>
        <severity value="error"/>
