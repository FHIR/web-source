    <element id="DV_CODED_TEXT.language">
      <path value="DV_CODED_TEXT.language"/>
      <short value="Optional indicator of the localised language in which the value is written."/>
      <definition value="Optional indicator of the localised language in which the value is written. Coded from openEHR Code Set  languages . Only used when either the text object is in a different language from the enclosing `ENTRY`, or else the text object is being used outside of an `ENTRY` or other enclosing structure which indicates the language."/>
      <min value="0"/>
      <max value="1"/>
