      <short value="The time interval during which the participation took place, if it is used in an observational context (i."/>
      <definition value="The time interval during which the participation took place, if it is used in an observational context (i.e. recording facts about the past); or the intended time interval of the participation when used in future contexts, such as EHR Instructions."/>
      <min value="0"/>
      <max value="1"/>
      <base>
        <path value="EXTRACT_PARTICIPATION.time"/>
        <min value="0"/>
        <max value="1"/>
