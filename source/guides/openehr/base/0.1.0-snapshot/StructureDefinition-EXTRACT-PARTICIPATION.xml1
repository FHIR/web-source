    <element id="EXTRACT_PARTICIPATION.mode">
      <path value="EXTRACT_PARTICIPATION.mode"/>
      <short value="The mode of the performer / activity interaction, e."/>
      <definition value="The mode of the performer / activity interaction, e.g. present, by telephone, by email etc."/>
