      </type>
      <isModifier value="false"/>
    </element>
    <element id="EXTRACT_PARTICIPATION.function">
      <path value="EXTRACT_PARTICIPATION.function"/>
      <short value="The function of the Party in this participation (note that a given party might participate in more than one way in a particular activity)."/>
      <definition value="The function of the Party in this participation (note that a given party might participate in more than one way in a particular activity). This attribute should be coded, but cannot be limited to the HL7v3:ParticipationFunction vocabulary, since it is too limited and hospital-oriented."/>
      <min value="1"/>
      <max value="1"/>
      <base>
