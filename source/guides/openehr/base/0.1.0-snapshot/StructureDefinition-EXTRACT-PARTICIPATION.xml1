      <constraint>
        <key value="Function_valid"/>
        <severity value="error"/>
        <human value="Function valid must be present"/>
        <expression value="function.exists() and then function.generating_type.is_equal (“DV_CODED_TEXT”) implies terminology (Terminology_id_openehr).has_code_for_group_id (Group_id_participation_function, function.defining_code)"/>
      </constraint>
      <constraint>
        <key value="Mode_valid"/>
        <severity value="error"/>
        <human value="Mode valid must be present"/>
        <expression value="mode.exists() and terminology (Terminology_id_openehr).has_code_for_group_id (Group_id_participation_mode, mode.defining_code)"/>
      </constraint>
      <isModifier value="false"/>
      <mapping>
