  <differential>
    <element id="EXTRACT_SPEC">
      <path value="EXTRACT_SPEC"/>
      <short value="Specification of an Extract's contents."/>
      <definition value="Specification of an Extract's contents. Subtypes can be used to add details specific to the type of Extract. The specification consists of attributes specifying the directory, and two further groups of attributes in their own classes, namely a version specfication (which versions of information items are to be included) and a manifest (which entities are to be included in the extract).&#xA;&#xA;Use: Used in a request to specify an Extract, as well as to describe what is contained in an Extract."/>
      <min value="0"/>
      <max value="*"/>
      <isModifier value="false"/>
    </element>
