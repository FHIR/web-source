      <short value="Unique identifier of this version container in the form of a UID with no extension."/>
      <definition value="Unique identifier of this version container in the form of a UID with no extension. This id will be the same in all instances of the same container in a distributed environment, meaning that it can be understood as the uid of the  virtual version tree."/>
      <min value="1"/>
      <max value="1"/>
      <base>
