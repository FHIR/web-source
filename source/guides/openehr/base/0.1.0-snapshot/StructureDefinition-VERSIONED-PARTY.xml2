    <element id="VERSIONED_PARTY">
      <path value="VERSIONED_PARTY"/>
      <short value="Static type formed by binding generic parameter of `VERSIONED_OBJECT&lt;T&gt;` to `PARTY`."/>
      <definition value="Static type formed by binding generic parameter of `VERSIONED_OBJECT&lt;T&gt;` to `PARTY`. "/>
      <min value="0"/>
      <max value="*"/>
      <base>
        <path value="Base"/>
        <min value="0"/>
        <max value="*"/>
      </base>
      <constraint>
        <key value="Version_count_valid"/>
        <severity value="error"/>
        <human value="Version count valid must satisfy range constraints"/>
        <expression value="version_count() &gt;= 0"/>
        <source value="http://openehr.org/fhir/StructureDefinition/VERSIONED-OBJECT"/>
      </constraint>
      <constraint>
        <key value="All_version_ids_valid"/>
        <severity value="error"/>
        <human value="All version ids valid"/>
        <expression value="all_version_ids().count() = version_count()"/>
        <source value="http://openehr.org/fhir/StructureDefinition/VERSIONED-OBJECT"/>
      </constraint>
      <constraint>
        <key value="All_versions_valid"/>
        <severity value="error"/>
        <human value="All versions valid"/>
        <expression value="all_versions().count() = version_count()"/>
        <source value="http://openehr.org/fhir/StructureDefinition/VERSIONED-OBJECT"/>
      </constraint>
      <constraint>
        <key value="Latest_version_valid"/>
        <severity value="error"/>
        <human value="Latest version valid must be present"/>
        <expression value="version_count() &gt; 0 implies latest_version().exists()"/>
        <source value="http://openehr.org/fhir/StructureDefinition/VERSIONED-OBJECT"/>
      </constraint>
      <constraint>
        <key value="Uid_validity"/>
        <severity value="error"/>
        <human value="Uid validity must not be empty"/>
        <expression value="extension.empty()"/>
        <source value="http://openehr.org/fhir/StructureDefinition/VERSIONED-OBJECT"/>
      </constraint>
      <isModifier value="false"/>
      <mapping>
        <identity value="rim"/>
        <map value="n/a"/>
      </mapping>
    </element>
