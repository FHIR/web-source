      <short value="Reference to object to which this version container belongs, e."/>
      <definition value="Reference to object to which this version container belongs, e.g. the id of the containing EHR or other relevant owning entity."/>
      <min value="1"/>
      <max value="1"/>
      <base>
        <path value="VERSIONED_OBJECT.owner_id"/>
        <min value="1"/>
        <max value="1"/>
      </base>
