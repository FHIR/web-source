      <short value="Name of the class (concrete or abstract) of object to which this identifier type refers. These class names are from the relevant reference model"/>
      <definition value="Name of the class (concrete or abstract) of object to which this identifier type refers, e.g. PARTY, PERSON, GUIDELINE etc. These class names are from the relevant reference model. The type name ANY can be used to indicate that any type is accepted (e.g. if the type is unknown)."/>
      <min value="1"/>
      <max value="1"/>
