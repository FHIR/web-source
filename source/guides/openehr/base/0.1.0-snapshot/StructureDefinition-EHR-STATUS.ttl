       fhir:path [ fhir:v "EHR_STATUS.is_modifiable" ] ;
       fhir:short [ fhir:v "True if the EHR, other than the `EHR_STATUS` object, is allowed to be written to." ] ;
       fhir:definition [ fhir:v "True if the EHR, other than the `EHR_STATUS` object, is allowed to be written to. The `EHR_STATUS` object itself can always be written to." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "boolean"^^xsd:anyURI ;
           fhir:l fhir:boolean
         ]
       ] ) ;
       fhir:isModifier [ fhir:v false ]
     ] [
       fhir:id [ fhir:v "EHR_STATUS.other-details" ] ;
       fhir:path [ fhir:v "EHR_STATUS.other_details" ] ;
       fhir:short [ fhir:v "Any other details of the EHR summary object, in the form of an archetyped `ITEM_STRUCTURE`." ] ;
       fhir:definition [ fhir:v "Any other details of the EHR summary object, in the form of an archetyped `ITEM_STRUCTURE`." ] ;
