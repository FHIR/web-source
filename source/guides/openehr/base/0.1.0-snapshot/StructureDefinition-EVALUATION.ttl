           fhir:l <http://openehr.org/fhir/StructureDefinition/LOCATABLE>
         ]
       ] [
         fhir:key [ fhir:v "Archetyped_valid" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Archetyped valid must satisfy exclusive conditions" ] ;
