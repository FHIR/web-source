    <element id="EHR">
      <path value="EHR"/>
      <short value="The EHR object is the root object and access point of an EHR for a subject of care."/>
      <definition value="The EHR object is the root object and access point of an EHR for a subject of care. "/>
      <min value="0"/>
      <max value="*"/>
      <base>
        <path value="Base"/>
        <min value="0"/>
        <max value="*"/>
      </base>
      <constraint>
        <key value="Contributions_valid"/>
        <severity value="error"/>
        <human value="Contributions valid"/>
        <expression value="for_all c in contributions | c.type().is_equal(\&quot;CONTRIBUTION\&quot;)"/>
      </constraint>
      <constraint>
        <key value="Ehr_access_valid"/>
        <severity value="error"/>
        <human value="Ehr access valid"/>
        <expression value="ehr_access.type().is_equal (\&quot;VERSIONED_EHR_ACCESS\&quot;)"/>
      </constraint>
      <constraint>
        <key value="Ehr_status_valid"/>
        <severity value="error"/>
        <human value="Ehr status valid"/>
        <expression value="ehr_status.type().is_equal(\&quot;VERSIONED_EHR_STATUS\&quot;)"/>
      </constraint>
      <constraint>
        <key value="Compositions_valid"/>
        <severity value="error"/>
        <human value="Compositions valid"/>
        <expression value="for_all c in compositions | c.type().is_equal (\&quot;VERSIONED_COMPOSITION\&quot;)"/>
      </constraint>
      <constraint>
        <key value="Directory_valid"/>
        <severity value="error"/>
        <human value="Directory valid must be present"/>
        <expression value="directory.exists() implies directory.type().is_equal (\&quot;VERSIONED_FOLDER\&quot;)"/>
      </constraint>
      <constraint>
        <key value="Folders_valid"/>
        <severity value="error"/>
        <human value="Folders valid must be present"/>
        <expression value="folders.exists() implies for_all f in folders | f.type().is_equal(\&quot;VERSIONED_FOLDER\&quot;)"/>
      </constraint>
      <constraint>
        <key value="Directory_in_folders"/>
        <severity value="error"/>
        <human value="Directory in folders must be present"/>
        <expression value="folders.exists() implies folders.item(1) = directory"/>
      </constraint>
      <isModifier value="false"/>
      <mapping>
        <identity value="rim"/>
        <map value="n/a"/>
      </mapping>
    </element>
