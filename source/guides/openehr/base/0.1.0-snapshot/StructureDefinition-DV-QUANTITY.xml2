    <OperationDefinition>
      <id value="is_strictly_comparable_to"/>
      <name value="is_strictly_comparable_to"/>
      <title value="is_strictly_comparable_to"/>
      <status value="active"/>
      <kind value="operation"/>
      <description value="True if this quantity and `_other_` have the same `_units_` and also `_units_system_` if it exists."/>
      <code value="is_strictly_comparable_to"/>
      <system value="false"/>
      <instance value="true"/>
      <parameter>
