  <contained>
    <OperationDefinition>
      <id value="is_external"/>
      <name value="is_external"/>
      <title value="is_external"/>
      <status value="active"/>
      <kind value="operation"/>
      <description value="Computed from the value of the `_uri_` attribute: True if  the data is stored externally to the record, as indicated by `_uri_`. A copy may also be stored internally, in which case `_is_expanded_` is also true."/>
      <code value="is_external"/>
      <system value="false"/>
      <instance value="true"/>
      <parameter>
        <name value="return"/>
        <use value="out"/>
        <min value="1"/>
        <max value="1"/>
        <type value="boolean"/>
      </parameter>
    </OperationDefinition>
  </contained>
  <contained>
    <OperationDefinition>
      <id value="is_inline"/>
      <name value="is_inline"/>
      <title value="is_inline"/>
      <status value="active"/>
      <kind value="operation"/>
      <description value="Computed from the value of the data attribute. True if  the  data is stored  in  expanded  form, ie within the EHR itself. "/>
      <code value="is_inline"/>
      <system value="false"/>
      <instance value="true"/>
      <parameter>
        <name value="return"/>
        <use value="out"/>
        <min value="1"/>
        <max value="1"/>
        <type value="boolean"/>
      </parameter>
    </OperationDefinition>
  </contained>
  <contained>
