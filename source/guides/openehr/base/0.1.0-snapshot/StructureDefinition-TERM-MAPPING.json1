        "min" : 0,
        "max" : "1"
      },
      "type" : [{
        "code" : "http://openehr.org/fhir/StructureDefinition/DV-CODED-TEXT"
      }],
      "isModifier" : false
    },
    {
      "id" : "TERM_MAPPING.target",
