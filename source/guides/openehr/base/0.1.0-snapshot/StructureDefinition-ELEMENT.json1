    {
      "id" : "ELEMENT.null-flavour",
      "path" : "ELEMENT.null_flavour",
      "short" : "Flavour of null value, e.",
      "definition" : "Flavour of null value, e.g. `253|unknown|`, `271|no information|`, `272|masked|`, and `273|not applicable|`.",
