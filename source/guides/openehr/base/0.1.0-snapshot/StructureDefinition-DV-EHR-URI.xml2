    <element id="DV_EHR_URI">
      <path value="DV_EHR_URI"/>
      <short value="A `DV_EHR_URI` is a `DV_URI` which has the scheme name 'ehr', and which can only reference items in EHRs."/>
      <definition value="A `DV_EHR_URI` is a `DV_URI` which has the scheme name 'ehr', and which can only reference items in EHRs. &#xA;&#xA;Used to reference items in an EHR, which may be the same as the current EHR (containing this link), or another."/>
      <min value="0"/>
