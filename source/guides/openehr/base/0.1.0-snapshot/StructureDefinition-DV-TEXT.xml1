  <differential>
    <element id="DV_TEXT">
      <path value="DV_TEXT"/>
      <short value="A text item, which may contain any amount of legal characters arranged as e."/>
      <definition value="A text item, which may contain any amount of legal characters arranged as e.g. words, sentences etc (i.e. one `DV_TEXT` may be more than one word). Visual formatting and hyperlinks may be included via markdown.&#xA;&#xA;If the `_formatting_` field is set, the `_value_` field is affected as follows:&#xA;&#xA;* `_formatting_ = &quot;plain&quot;`: plain text, may contain newlines;&#xA;* `_formatting_ = &quot;plain_no_newlines&quot;`: plain text with no newlines;&#xA;* `_formatting_ = &quot;markdown&quot;`: text in markdown format; use of CommonMark strongly recommended.&#xA;&#xA;A `DV_TEXT` can be coded by adding mappings to it."/>
      <min value="0"/>
      <max value="*"/>
      <constraint>
        <key value="Valid_value"/>
        <severity value="error"/>
        <human value="Valid value must not be empty"/>
        <expression value="value.empty().not()"/>
      </constraint>
      <constraint>
        <key value="Mappings_valid"/>
        <severity value="error"/>
        <human value="Mappings valid must not be empty"/>
        <expression value="mappings /= void implies mappings.empty().not()"/>
      </constraint>
      <constraint>
        <key value="Formatting_valid"/>
        <severity value="error"/>
        <human value="Formatting valid must not be empty"/>
        <expression value="formatting /= void implies formatting.empty().not()"/>
      </constraint>
      <isModifier value="false"/>
      <binding>
        <strength value="required"/>
        <valueSet value="https://specifications.openehr.org/fhir/valueset-character_sets"/>
      </binding>
    </element>
