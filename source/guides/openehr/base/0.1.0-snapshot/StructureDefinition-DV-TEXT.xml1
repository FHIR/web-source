        <human value="Mappings valid must not be empty"/>
        <expression value="mappings /= void implies mappings.empty().not()"/>
      </constraint>
      <constraint>
        <key value="Formatting_valid"/>
        <severity value="error"/>
        <human value="Formatting valid must not be empty"/>
        <expression value="formatting /= void implies formatting.empty().not()"/>
      </constraint>
      <isModifier value="false"/>
      <mapping>
        <identity value="rim"/>
        <map value="n/a"/>
      </mapping>
    </element>
