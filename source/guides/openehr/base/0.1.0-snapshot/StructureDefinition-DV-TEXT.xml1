      <short value="Terms from other terminologies most closely matching this term, typically used where the originator (e."/>
      <definition value="Terms from other terminologies most closely matching this term, typically used where the originator (e.g. pathology lab) of information uses a local terminology but also supplies one or more equivalents from well known terminologies (e.g. LOINC)."/>
      <min value="0"/>
      <max value="*"/>
      <base>
        <path value="DV_TEXT.mappings"/>
