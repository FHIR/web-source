    <element id="ACTION.encoding">
      <path value="ACTION.encoding"/>
      <short value="Name of character set in which text values in this Entry are encoded."/>
      <definition value="Name of character set in which text values in this Entry are encoded. Coded from openEHR Code Set  character sets."/>
      <min value="1"/>
      <max value="1"/>
