  </contained>
  <contained>
    <OperationDefinition>
      <id value="code_set_identifiers"/>
      <name value="code_set_identifiers"/>
      <title value="code_set_identifiers"/>
      <status value="active"/>
      <kind value="operation"/>
      <description value="Set of all code sets identifiers for which there is an internal openEHR name; returned as a Map of ids keyed by internal name. "/>
