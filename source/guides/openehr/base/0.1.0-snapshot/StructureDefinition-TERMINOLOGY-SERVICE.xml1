      <code value="code_set"/>
      <system value="false"/>
      <instance value="true"/>
      <parameter>
        <name value="name"/>
        <use value="in"/>
        <min value="1"/>
        <max value="1"/>
        <type value="string"/>
      </parameter>
      <parameter>
        <name value="return"/>
        <use value="out"/>
        <min value="1"/>
        <max value="1"/>
        <type value="Parameters"/>
      </parameter>
    </OperationDefinition>
  </contained>
  <contained>
    <OperationDefinition>
      <id value="code_set_for_id"/>
      <name value="code_set_for_id"/>
      <title value="code_set_for_id"/>
      <status value="active"/>
      <kind value="operation"/>
