  <contained>
    <OperationDefinition>
      <id value="terminology"/>
      <name value="terminology"/>
      <title value="terminology"/>
      <status value="active"/>
      <kind value="operation"/>
      <description value="Return an interface to the terminology named name. Allowable names include:-&#xA;&#xA;* openehr, &#xA;* centc251,&#xA;* any name from are taken from the US NLM UMLS meta-data list at http://www.nlm.nih.gov/research/umls/metaa1.html "/>
      <code value="terminology"/>
      <system value="false"/>
      <instance value="true"/>
      <parameter>
        <name value="name"/>
        <use value="in"/>
        <min value="1"/>
        <max value="1"/>
        <type value="string"/>
      </parameter>
      <parameter>
        <name value="return"/>
        <use value="out"/>
        <min value="1"/>
        <max value="1"/>
        <type value="Parameters"/>
      </parameter>
    </OperationDefinition>
  </contained>
  <contained>
    <OperationDefinition>
      <id value="code_set"/>
      <name value="code_set"/>
      <title value="code_set"/>
      <status value="active"/>
      <kind value="operation"/>
