        <use value="out"/>
        <min value="1"/>
        <max value="1"/>
        <type value="Parameters"/>
      </parameter>
    </OperationDefinition>
  </contained>
  <contained>
    <OperationDefinition>
      <id value="has_terminology"/>
      <name value="has_terminology"/>
      <title value="has_terminology"/>
      <status value="active"/>
      <kind value="operation"/>
      <description value="True if terminology named name known by this service. Allowable names include:-&#xA;&#xA;*  openehr  &#xA;* centc251  &#xA;* any name from are taken from the US NLM UMLS meta-data list at       http://www.nlm.nih.gov/research/umls/metaa1.html"/>
      <code value="has_terminology"/>
      <system value="false"/>
      <instance value="true"/>
      <parameter>
        <name value="name"/>
        <use value="in"/>
        <min value="1"/>
        <max value="1"/>
        <type value="string"/>
      </parameter>
      <parameter>
        <name value="return"/>
        <use value="out"/>
        <min value="1"/>
        <max value="1"/>
        <type value="boolean"/>
      </parameter>
    </OperationDefinition>
  </contained>
  <contained>
    <OperationDefinition>
      <id value="has_code_set"/>
      <name value="has_code_set"/>
      <title value="has_code_set"/>
      <status value="active"/>
      <kind value="operation"/>
      <description value="True if code_set linked to internal name (e.g. languages ) is available. "/>
      <code value="has_code_set"/>
      <system value="false"/>
      <instance value="true"/>
      <parameter>
        <name value="name"/>
        <use value="in"/>
        <min value="1"/>
        <max value="1"/>
