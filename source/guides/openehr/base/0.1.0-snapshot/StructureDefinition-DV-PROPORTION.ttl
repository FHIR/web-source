  fhir:differential [
     fhir:element ( [
       fhir:id [ fhir:v "DV_PROPORTION" ] ;
       fhir:path [ fhir:v "DV_PROPORTION" ] ;
       fhir:short [ fhir:v "Models a ratio of values, i." ] ;
       fhir:definition [ fhir:v "Models a ratio of values, i.e. where the numerator and denominator are both pure numbers. The `_valid_proportion_kind_` property of the `PROPORTION_KIND` class is used to control the type attribute to be one of a defined set.\n\nUsed for recording titers (e.g. 1:128), concentration ratios, e.g. Na:K (unitary denominator), albumin:creatinine ratio, and percentages, e.g. red cell distirbution width (RDW). \n \nMisuse: Should not be used to represent things like blood pressure which are often written using a  '/' character, giving the misleading impression that the item is a ratio, when in fact it is a structured value. Similarly, visual acuity, often written as (e.g.) \"6/24\" in clinical notes is not a ratio but an ordinal (which includes non-numeric symbols like CF = count fingers etc). Should not be used for formulations. " ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "Type_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Type validity" ] ;
         fhir:expression [ fhir:v "null # TODO: manual translation needed" ]
       ] [
         fhir:key [ fhir:v "Precision_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Precision validity must satisfy conditional constraints" ] ;
         fhir:expression [ fhir:v "precision = 0 implies is_integral()" ]
       ] [
         fhir:key [ fhir:v "Is_integral_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Is integral validity must satisfy conditional constraints" ] ;
         fhir:expression [ fhir:v "is_integral() implies (numerator.floor = numerator and denominator.floor = denominator)" ]
       ] [
         fhir:key [ fhir:v "Fraction_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Fraction validity must satisfy conditional constraints" ] ;
         fhir:expression [ fhir:v "(type = pk_fraction or type = pk_integer_fraction) implies is_integral()" ]
       ] [
         fhir:key [ fhir:v "Unitary_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Unitary validity must satisfy conditional constraints" ] ;
         fhir:expression [ fhir:v "null # TODO: manual translation needed" ]
       ] [
         fhir:key [ fhir:v "Percent_validity" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Percent validity must satisfy conditional constraints" ] ;
         fhir:expression [ fhir:v "null # TODO: manual translation needed" ]
       ] [
         fhir:key [ fhir:v "Valid_denominator" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Valid denominator" ] ;
         fhir:expression [ fhir:v "null # TODO: manual translation needed" ]
       ] ) ;
       fhir:isModifier [ fhir:v false ]
     ] [
