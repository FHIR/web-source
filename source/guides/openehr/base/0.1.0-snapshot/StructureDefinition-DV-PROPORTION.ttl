       fhir:path [ fhir:v "DV_PROPORTION.numerator" ] ;
       fhir:short [ fhir:v "Numerator of ratio" ] ;
       fhir:definition [ fhir:v "Numerator of ratio" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
