     ] [
       fhir:id [ fhir:v "COMPOSITION.category" ] ;
       fhir:path [ fhir:v "COMPOSITION.category" ] ;
       fhir:short [ fhir:v "Temporal category of this Composition, i." ] ;
       fhir:definition [ fhir:v "Temporal category of this Composition, i.e. \n\n* `431|persistent|` - of potential life-time validity;\n* `451|episodic|` - valid over the life of a care episode;\n* `433|event|` - valid at the time of recording (long-term validity requires subsequent clinical assessment).\n\nor any other code defined in the openEHR terminology group 'category'.\n" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
