           fhir:l <http://openehr.org/fhir/StructureDefinition/CODE-PHRASE>
         ]
       ] ) ;
       fhir:isModifier [ fhir:v false ]
     ] [
       fhir:id [ fhir:v "COMPOSITION.territory" ] ;
       fhir:path [ fhir:v "COMPOSITION.territory" ] ;
       fhir:short [ fhir:v "Name of territory in which this Composition was written." ] ;
       fhir:definition [ fhir:v "Name of territory in which this Composition was written. Coded from openEHR  countries  code set, which is an expression of the ISO 3166 standard." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
