         ]
       ] ) ;
       fhir:isModifier [ fhir:v false ]
     ] [
       fhir:id [ fhir:v "COMPOSITION.context" ] ;
       fhir:path [ fhir:v "COMPOSITION.context" ] ;
       fhir:short [ fhir:v "The clinical session context of this Composition, i." ] ;
       fhir:definition [ fhir:v "The clinical session context of this Composition, i.e. the contextual attributes of the clinical session. " ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [
