         fhir:expression [ fhir:v "(upper_unbounde.not()d and lower_unbounded.not()) implies (lower.is_strictly_comparable_to(upper) and lower <= upper)" ]
       ] ) ;
       fhir:isModifier [ fhir:v false ]
     ] )
