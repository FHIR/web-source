      <path value="ATTESTATION.time_committed"/>
      <short value="Time of committal of the item."/>
      <definition value="Time of committal of the item."/>
      <min value="1"/>
      <max value="1"/>
      <base>
        <path value="AUDIT_DETAILS.time_committed"/>
        <min value="1"/>
        <max value="1"/>
