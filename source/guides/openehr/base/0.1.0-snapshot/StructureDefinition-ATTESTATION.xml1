      <type>
        <code value="http://openehr.org/fhir/StructureDefinition/DV-DATE-TIME"/>
      </type>
      <isModifier value="false"/>
    </element>
    <element id="ATTESTATION.change-type">
      <path value="ATTESTATION.change_type"/>
      <short value="Type of change."/>
      <definition value="Type of change. Coded using the openEHR Terminology  audit change type  group."/>
      <min value="1"/>
      <max value="1"/>
      <base>
        <path value="AUDIT_DETAILS.change_type"/>
        <min value="1"/>
        <max value="1"/>
      </base>
      <type>
