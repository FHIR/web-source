    <element id="ORIGINAL_VERSION">
      <path value="ORIGINAL_VERSION"/>
      <short value="A Version containing locally created content and optional attestations."/>
      <definition value="A Version containing locally created content and optional attestations. "/>
      <min value="0"/>
      <max value="*"/>
      <base>
        <path value="Base"/>
        <min value="0"/>
        <max value="*"/>
      </base>
      <constraint>
        <key value="Owner_id_valid"/>
        <severity value="error"/>
        <human value="Owner id valid"/>
        <expression value="owner_id().value().is_equal (uid().object_id.value())"/>
        <source value="http://openehr.org/fhir/StructureDefinition/VERSION"/>
      </constraint>
      <constraint>
        <key value="Preceding_version_uid_validity"/>
        <severity value="error"/>
        <human value="Preceding version uid validity must be present"/>
        <expression value="uid().version_tree_id.is_first xor preceding_version_uid().exists()"/>
        <source value="http://openehr.org/fhir/StructureDefinition/VERSION"/>
      </constraint>
      <constraint>
        <key value="Lifecycle_state_ valid"/>
        <severity value="error"/>
        <human value="Lifecycle state  valid must be present"/>
        <expression value="lifecycle_state().exists() and then terminology (Term_id_openehr).has_code_for_group_id (Group_id_version_lifecycle_state, lifecycle_state().defining_code)"/>
        <source value="http://openehr.org/fhir/StructureDefinition/VERSION"/>
      </constraint>
      <constraint>
        <key value="Attestations_valid"/>
        <severity value="error"/>
        <human value="Attestations valid must be present"/>
        <expression value="attestations.exists() implies attestations.empty().not()"/>
      </constraint>
      <constraint>
        <key value="Is_merged_validity"/>
        <severity value="error"/>
        <human value="Is merged validity must satisfy exclusive conditions"/>
        <expression value="other_input_version_ids .empty() xor is_merged()"/>
      </constraint>
      <constraint>
        <key value="Other_input_version_uids_valid"/>
        <severity value="error"/>
        <human value="Other input version uids valid must be present"/>
        <expression value="other_input_version_uids.exists() implies other_input_version_uids.empty().not()"/>
      </constraint>
      <isModifier value="false"/>
      <mapping>
        <identity value="rim"/>
        <map value="n/a"/>
      </mapping>
    </element>
