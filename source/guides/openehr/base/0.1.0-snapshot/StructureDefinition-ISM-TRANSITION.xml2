    <element id="ISM_TRANSITION.careflow-step">
      <path value="ISM_TRANSITION.careflow_step"/>
      <short value="The step in the careflow process which occurred as part of generating this action, e."/>
      <definition value="The step in the careflow process which occurred as part of generating this action, e.g.  dispense ,  start_administration. This attribute represents the clinical  label for the activity, as  opposed to current_state which represents  the state machine (ISM)  computable form. Defined in archetype."/>
