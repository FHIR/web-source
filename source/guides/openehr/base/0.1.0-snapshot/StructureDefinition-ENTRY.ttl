       fhir:short [ fhir:v "Optional identification of provider of the information in this `ENTRY`, which might be: \n\n* the patient \n* a patient agent, e." ] ;
       fhir:definition [ fhir:v "Optional identification of provider of the information in this `ENTRY`, which might be: \n\n* the patient \n* a patient agent, e.g. parent, guardian \n* the clinician \n* a device or software \n\nGenerally only used when the recorder needs to make it explicit. Otherwise, Composition composer and other participants are assumed. \n" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://openehr.org/fhir/StructureDefinition/PARTY-PROXY"^^xsd:anyURI ;
           fhir:l <http://openehr.org/fhir/StructureDefinition/PARTY-PROXY>
         ]
       ] ) ;
       fhir:isModifier [ fhir:v false ]
     ] )
  ] . # 

